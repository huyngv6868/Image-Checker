# AI Vision Providers & Fallback (NVIDIA -> OpenRouter -> Gemini)
# The system tries clients in sequence until one succeeds.
# You can supply multiple comma-separated keys to avoid rate limits.

# 1. NVIDIA NIM (Primary)
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_API_KEYS=key1,key2,key3
# STOCKLINT_VLM_MODEL=nvidia/nemotron-nano-12b-v2-vl

# 2. OpenRouter (Fallback 1)
# OPENROUTER_API_KEYS=key1,key2
# OPENROUTER_MODEL=google/gemini-1.5-flash

# 3. Gemini (Fallback 2)
# GEMINI_API_KEYS=key1,key2
# GEMINI_MODEL=gemini-1.5-flash

# Optional: Deterministic small-face gate. If a detected face occupies less than this
# fraction of the frame -> anatomy fails (subject too small/distant to verify). 0 disables.
# STOCKLINT_FACE_MIN_FRAC=0.005

# Optional: Cap the longest image side sent to the model (px). Default is 2048.
# STOCKLINT_VLM_MAX_DIM=2048

# Optional: Max tokens for model output. Default is 700.
# STOCKLINT_VLM_MAX_TOKENS=700
