# AI vision now runs 100% LOCALLY on Apple Silicon (Qwen2.5-VL via MLX).
# No API key, no Ollama, no network. These are OPTIONAL overrides:

# Vision-language model (MLX community repo).
# Default = Qwen2.5-VL-3B-Instruct-4bit (~2GB RAM) — SAFE on a 24GB Mac running an IDE.
# Only go bigger if you have free RAM (8-bit 7B ≈ 9GB resident can exhaust 24GB and freeze):
#   better quality: mlx-community/Qwen2.5-VL-7B-Instruct-4bit   (~4.5GB)
#   max quality:    mlx-community/Qwen2.5-VL-7B-Instruct-8bit   (~9GB, risky on 24GB)
# STOCKLINT_VLM_MODEL=mlx-community/Qwen2.5-VL-3B-Instruct-4bit

# Cap the longest image side sent to the model (px). Higher = more legible text but MUCH
# more RAM/time (memory grows ~quadratically). 1024 is safe; raise cautiously.
# STOCKLINT_VLM_MAX_DIM=1024

# Hard cap (GB) on unified memory MLX may hold — backstop so a big image can't swap-freeze the Mac.
# STOCKLINT_VLM_MEM_LIMIT_GB=10
